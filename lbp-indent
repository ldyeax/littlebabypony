tabs=${1:-"1"}
if [[ $tabs -eq 0 ]]; then
	cat
elif [[ $tabs -lt 0 ]]; then
    remove=$(( -tabs ))

    while IFS= read -r line; do
        count=0

        while [[ $line == $'\t'* && $count -lt $remove ]]; do
            line=${line#$'\t'}
            ((count++))
        done

        printf '%s\n' "$line"
    done
elif [[ $tabs -gt 0 ]]; then
	while IFS= read -r line; do
		for (( i=0; i<tabs; i++ )); do
			printf "\t"
		done
		printf "%s\n" "$line"
	done
fi
